{
  "tool": "inferctl",
  "binary": "inferctl",
  "contract_version": "0.1",
  "features": [
    "json_envelope",
    "stderr_error_mirror",
    "did_you_mean",
    "contract_goldens",
    "deterministic_test_mode",
    "config_provenance",
    "config_mutation",
    "from_stdin",
    "delivery_artifacts",
    "mega_command_capabilities",
    "mega_command_diagnose",
    "mega_command_plan",
    "mega_command_triage"
  ],
  "global_flags": {
    "--help": {
      "type": "bool",
      "default": false,
      "description": "Show terse human help with exit-code and automation guidance."
    },
    "--json": {
      "type": "bool",
      "default": false,
      "description": "Emit the universal JSON envelope on stdout."
    }
  },
  "limits": {
    "discovery": {
      "mode": "localhost_fixed_ports",
      "default_timeout_ms": 750,
      "minimum_timeout_ms": 100,
      "default_ports": [
        1234,
        8080,
        8081,
        8090,
        11434
      ]
    },
    "triage": {
      "default_limit": 0,
      "limit_zero_means": "unbounded"
    }
  },
  "config": {
    "format": "toml",
    "schema_uri": "inferctl config explain --json",
    "show_uri": "inferctl config show --json",
    "validate_uri": "inferctl config validate --json",
    "search_path": [
      "$INFERCTL_CONFIG",
      "./inferctl.toml",
      "$XDG_CONFIG_HOME/inferctl/config.toml",
      "$HOME/.config/inferctl/config.toml"
    ],
    "precedence": [
      "flag",
      "env",
      "file",
      "default"
    ],
    "supports_profiles": false,
    "mutation_verbs": [
      "config init",
      "config set",
      "config patch"
    ]
  },
  "schemas_uri": "inferctl capabilities --json | jq '.data.schemas'",
  "robot_docs_uri": "docs/agent-guide.md",
  "known_non_goals": [
    "No model-quality benchmarking.",
    "No inference execution API in v0.2.",
    "No release binaries, archives, installers, Homebrew formula, or Scoop manifest for the current Go-install-only launch posture.",
    "No automatic remote backend use unless config explicitly opts in with remote_allowed=true."
  ],
  "docs": [
    {
      "name": "agent_guide",
      "path": "docs/agent-guide.md",
      "description": "Agent-facing workflows for setup, config mutation, discovery, triage, routing, auth, and model-family quirks."
    },
    {
      "name": "install",
      "path": "docs/install.md",
      "description": "Go toolchain installation guidance; no release binaries, archives, installers, Homebrew formulae, or Scoop manifests are published for the current launch posture."
    },
    {
      "name": "verbs",
      "path": "docs/verbs.md",
      "description": "Generated CLI verb contract."
    },
    {
      "name": "errors",
      "path": "docs/errors.md",
      "description": "Generated error and warning catalog."
    }
  ],
  "examples": {
    "packaging": "source_only",
    "decision": "v0.2 examples are source checkout scripts, not release-package artifacts; no packaged examples or release archives are planned for the current Go-install-only launch posture.",
    "paths": [
      "examples/demo-1-install-moment.sh",
      "examples/demo-2-route-explained.sh",
      "examples/demo-3-agent-loop.sh"
    ]
  },
  "backend_kinds": [
    {
      "name": "ollama",
      "status": "v0.1"
    },
    {
      "name": "llama.cpp",
      "status": "v0.1"
    },
    {
      "name": "openai_compat",
      "status": "v0.1"
    },
    {
      "name": "lmstudio",
      "status": "v0.2"
    },
    {
      "name": "mlx",
      "status": "v0.2"
    }
  ],
  "verbs": [
    {
      "name": "doctor",
      "summary": "Health, loaded models, and route resolution across configured backends.",
      "mega_command": "DIAGNOSE",
      "flags": [
        {
          "name": "--json",
          "type": "bool",
          "default": false
        },
        {
          "name": "--fast",
          "type": "bool",
          "default": false
        },
        {
          "name": "--backend",
          "type": "string",
          "default": null
        }
      ],
      "exit_codes": [
        0,
        3,
        4
      ],
      "output_schema_ref": "#/schemas/doctor_report",
      "emits_data_on_failure": false
    },
    {
      "name": "backends",
      "summary": "List configured backends with reachability status.",
      "flags": [
        {
          "name": "--filter",
          "type": "string",
          "default": null
        },
        {
          "name": "--kind",
          "type": "string",
          "default": null
        },
        {
          "name": "--json",
          "type": "bool",
          "default": false
        },
        {
          "name": "--fast",
          "type": "bool",
          "default": false
        }
      ],
      "exit_codes": [
        0,
        3
      ],
      "output_schema_ref": "#/schemas/backend_list",
      "emits_data_on_failure": false
    },
    {
      "name": "models",
      "summary": "List installed or loaded models across configured backends.",
      "flags": [
        {
          "name": "--backend",
          "type": "string",
          "default": null
        },
        {
          "name": "--loaded",
          "type": "bool",
          "default": false
        },
        {
          "name": "--installed",
          "type": "bool",
          "default": true
        },
        {
          "name": "--json",
          "type": "bool",
          "default": false
        }
      ],
      "exit_codes": [
        0,
        3
      ],
      "output_schema_ref": "#/schemas/model_list",
      "emits_data_on_failure": false
    },
    {
      "name": "model",
      "summary": "Inspect one model's backend placements, capabilities, stats, and routing usage.",
      "flags": [
        {
          "name": "--json",
          "type": "bool",
          "default": false
        },
        {
          "name": "--no-probe",
          "type": "bool",
          "default": false
        }
      ],
      "args": [
        {
          "name": "model_name",
          "required": true
        }
      ],
      "exit_codes": [
        0,
        1,
        3
      ],
      "output_schema_ref": "#/schemas/model_detail",
      "emits_data_on_failure": false
    },
    {
      "name": "route",
      "summary": "Compute and explain a route for a configured task.",
      "mega_command": "PLAN",
      "flags": [
        {
          "name": "--prompt-file",
          "type": "string",
          "default": null
        },
        {
          "name": "--prompt",
          "type": "string",
          "default": null
        },
        {
          "name": "--from-stdin",
          "type": "bool",
          "default": false
        },
        {
          "name": "--prefer",
          "type": "enum",
          "values": [
            "speed",
            "quality",
            "default"
          ],
          "default": "default"
        },
        {
          "name": "--explain",
          "type": "bool",
          "default": true
        },
        {
          "name": "--quiet",
          "type": "bool",
          "default": false
        },
        {
          "name": "--json",
          "type": "bool",
          "default": false
        }
      ],
      "args": [
        {
          "name": "task",
          "required": true
        }
      ],
      "exit_codes": [
        0,
        1,
        3,
        4
      ],
      "output_schema_ref": "#/schemas/route_explanation",
      "emits_data_on_failure": false
    },
    {
      "name": "config",
      "namespace_only": true,
      "summary": "Namespace for config show, validate, explain, init, set, and patch. Not directly invokable."
    },
    {
      "name": "config show",
      "summary": "Show the effective config with per-key provenance.",
      "flags": [
        {
          "name": "--section",
          "type": "string",
          "default": null
        },
        {
          "name": "--key",
          "type": "string",
          "default": null
        },
        {
          "name": "--no-provenance",
          "type": "bool",
          "default": false
        },
        {
          "name": "--json",
          "type": "bool",
          "default": false
        }
      ],
      "exit_codes": [
        0,
        3
      ],
      "output_schema_ref": "#/schemas/config_view",
      "emits_data_on_failure": false
    },
    {
      "name": "config validate",
      "summary": "Validate config and return source-position findings.",
      "flags": [
        {
          "name": "--strict",
          "type": "bool",
          "default": false
        },
        {
          "name": "--json",
          "type": "bool",
          "default": false
        }
      ],
      "exit_codes": [
        0,
        1,
        3
      ],
      "output_schema_ref": "#/schemas/config_validation",
      "emits_data_on_failure": true
    },
    {
      "name": "config explain",
      "summary": "Print annotated default config and machine-readable key definitions.",
      "flags": [
        {
          "name": "--key",
          "type": "string",
          "default": null
        },
        {
          "name": "--format",
          "type": "enum",
          "values": [
            "toml",
            "md"
          ],
          "default": "toml"
        },
        {
          "name": "--json",
          "type": "bool",
          "default": false
        }
      ],
      "exit_codes": [
        0,
        1
      ],
      "output_schema_ref": "#/schemas/config_explanation",
      "emits_data_on_failure": false
    },
    {
      "name": "config init",
      "summary": "Create or print a starter inferctl config.",
      "flags": [
        {
          "name": "--path",
          "type": "string",
          "default": null
        },
        {
          "name": "--force",
          "type": "bool",
          "default": false
        },
        {
          "name": "--print",
          "type": "bool",
          "default": false
        },
        {
          "name": "--json",
          "type": "bool",
          "default": false
        }
      ],
      "exit_codes": [
        0,
        1,
        3
      ],
      "output_schema_ref": "#/schemas/config_mutation",
      "emits_data_on_failure": false
    },
    {
      "name": "config set",
      "summary": "Set one config key while preserving surrounding TOML comments and ordering.",
      "flags": [
        {
          "name": "--path",
          "type": "string",
          "default": null
        },
        {
          "name": "--type",
          "type": "enum",
          "values": [
            "string",
            "int",
            "bool",
            "null",
            "array"
          ],
          "default": null
        },
        {
          "name": "--dry-run",
          "type": "bool",
          "default": false
        },
        {
          "name": "--json",
          "type": "bool",
          "default": false
        }
      ],
      "args": [
        {
          "name": "key",
          "required": true
        },
        {
          "name": "value",
          "required": true
        }
      ],
      "exit_codes": [
        0,
        1,
        3
      ],
      "output_schema_ref": "#/schemas/config_mutation",
      "emits_data_on_failure": false
    },
    {
      "name": "config patch",
      "summary": "Merge a TOML fragment into config without supporting deletions.",
      "flags": [
        {
          "name": "--path",
          "type": "string",
          "default": null
        },
        {
          "name": "--from-stdin",
          "type": "bool",
          "default": false
        },
        {
          "name": "--dry-run",
          "type": "bool",
          "default": false
        },
        {
          "name": "--json",
          "type": "bool",
          "default": false
        }
      ],
      "args": [
        {
          "name": "toml-fragment",
          "required": false
        }
      ],
      "exit_codes": [
        0,
        1,
        3
      ],
      "output_schema_ref": "#/schemas/config_mutation",
      "emits_data_on_failure": false
    },
    {
      "name": "discover",
      "summary": "Probe fixed localhost backend ports and report verified backend candidates.",
      "flags": [
        {
          "name": "--format",
          "type": "enum",
          "values": [
            "text",
            "json",
            "toml"
          ],
          "default": "text"
        },
        {
          "name": "--kind",
          "type": "enum",
          "values": [
            "ollama",
            "llama.cpp",
            "openai_compat",
            "lmstudio",
            "mlx"
          ],
          "default": null
        },
        {
          "name": "--timeout-ms",
          "type": "int",
          "default": 750
        },
        {
          "name": "--deliver",
          "type": "string",
          "default": null
        },
        {
          "name": "--json",
          "type": "bool",
          "default": false
        }
      ],
      "exit_codes": [
        0,
        1,
        3,
        4
      ],
      "output_schema_ref": "#/schemas/discovery_report",
      "emits_data_on_failure": false
    },
    {
      "name": "triage",
      "summary": "Rank deterministic diagnostic next actions from config validation, doctor output, or prior JSON envelopes.",
      "mega_command": "TRIAGE",
      "flags": [
        {
          "name": "--input-file",
          "type": "string",
          "default": null
        },
        {
          "name": "--backend",
          "type": "string",
          "default": null
        },
        {
          "name": "--severity",
          "type": "enum",
          "values": [
            "error",
            "warning",
            "info"
          ],
          "default": null
        },
        {
          "name": "--limit",
          "type": "int",
          "default": 0
        },
        {
          "name": "--json",
          "type": "bool",
          "default": false
        }
      ],
      "exit_codes": [
        0,
        1,
        3
      ],
      "output_schema_ref": "#/schemas/triage_report",
      "emits_data_on_failure": false
    },
    {
      "name": "capabilities",
      "summary": "Emit the machine-readable CLI contract.",
      "mega_command": "CAPABILITIES",
      "flags": [
        {
          "name": "--json",
          "type": "bool",
          "default": false
        }
      ],
      "exit_codes": [
        0
      ],
      "output_schema_ref": "#/schemas/capabilities_manifest",
      "emits_data_on_failure": false
    },
    {
      "name": "version",
      "summary": "Show version, build metadata, and optional update status.",
      "flags": [
        {
          "name": "--check",
          "type": "bool",
          "default": false
        },
        {
          "name": "--json",
          "type": "bool",
          "default": false
        }
      ],
      "exit_codes": [
        0
      ],
      "output_schema_ref": "#/schemas/version_info",
      "emits_data_on_failure": false
    }
  ],
  "exit_codes": {
    "0": {
      "name": "success",
      "retryable": false,
      "meaning": "Verb completed; data is valid."
    },
    "1": {
      "name": "user_input_error",
      "retryable": false,
      "meaning": "Bad invocation, invalid argument, or validation-style failure."
    },
    "2": {
      "name": "safety_block",
      "retryable": false,
      "meaning": "Destructive operation refused for missing confirmation or safer alternative."
    },
    "3": {
      "name": "tool_environment_error",
      "retryable": false,
      "meaning": "Tool environment, config, filesystem, or internal state is invalid."
    },
    "4": {
      "name": "transient_failure",
      "retryable": true,
      "meaning": "Operation may succeed on retry without user changes."
    },
    "5": {
      "name": "conflict",
      "retryable": false,
      "meaning": "Persistent conflict that requires intervention."
    }
  },
  "env_vars": [
    {
      "name": "INFERCTL_CONFIG",
      "honored": true,
      "description": "Override config file path."
    },
    {
      "name": "INFERCTL_FORMAT",
      "honored": true,
      "values": [
        "text",
        "json"
      ],
      "default": "text",
      "description": "Default output format; json makes every verb emit the envelope."
    },
    {
      "name": "INFERCTL_DEFAULT_BACKEND",
      "honored": true,
      "description": "Override default backend by setting exactly one configured backend default=true."
    },
    {
      "name": "INFERCTL_PROFILE_MODE",
      "honored": true,
      "values": [
        "strict",
        "warn",
        "advisory"
      ],
      "default": "warn",
      "description": "Override profile mode; v0.1 enforces warn semantics."
    },
    {
      "name": "INFERCTL_LOG_FORMAT",
      "honored": true,
      "values": [
        "text",
        "json"
      ],
      "default": "text",
      "description": "Select stderr diagnostic log format."
    },
    {
      "name": "INFERCTL_TEST_DETERMINISTIC",
      "honored": true,
      "description": "Fix request_id, ts_iso, and elapsed_ms for deterministic tests."
    },
    {
      "name": "NO_COLOR",
      "honored": true,
      "description": "Suppress ANSI color regardless of TTY."
    },
    {
      "name": "CI",
      "honored": true,
      "description": "Suppress ANSI color; does not change output format."
    },
    {
      "name": "TERM",
      "honored": true,
      "description": "TERM=dumb suppresses ANSI color."
    },
    {
      "name": "SOURCE_DATE_EPOCH",
      "honored": true,
      "description": "Determinism aid for ts_iso."
    }
  ],
  "envelope_version": "0.1",
  "schemas": {
    "doctor_report": {
      "$ref": "#/generated/doctor_report",
      "title": "DoctorReport"
    },
    "backend_list": {
      "$ref": "#/generated/backend_list",
      "title": "BackendList"
    },
    "model_list": {
      "$ref": "#/generated/model_list",
      "title": "ModelList"
    },
    "model_detail": {
      "$ref": "#/generated/model_detail",
      "title": "ModelDetail"
    },
    "route_explanation": {
      "$ref": "#/generated/route_explanation",
      "title": "RouteExplanation"
    },
    "config_view": {
      "$ref": "#/generated/config_view",
      "title": "ConfigView"
    },
    "config_validation": {
      "$ref": "#/generated/config_validation",
      "title": "ConfigValidation"
    },
    "config_explanation": {
      "$ref": "#/generated/config_explanation",
      "title": "ConfigExplanation"
    },
    "config_mutation": {
      "$ref": "#/generated/config_mutation",
      "title": "ConfigMutation"
    },
    "discovery_report": {
      "$ref": "#/generated/discovery_report",
      "title": "DiscoveryReport"
    },
    "triage_report": {
      "$ref": "#/generated/triage_report",
      "title": "TriageReport"
    },
    "version_info": {
      "$ref": "#/generated/version_info",
      "title": "VersionInfo"
    },
    "capabilities_manifest": {
      "$ref": "#/generated/capabilities_manifest",
      "title": "CapabilitiesManifest"
    },
    "error_details": {
      "$ref": "#/generated/error_details",
      "title": "ErrorDetails"
    },
    "warning_details": {
      "$ref": "#/generated/warning_details",
      "title": "WarningDetails"
    }
  },
  "error_codes": {
    "E_UNKNOWN_VERB": {
      "status": "v0.1",
      "exit_code": 1,
      "retryable": false,
      "message_template": "unknown verb '<verb>'",
      "details_schema_ref": "#/schemas/error_details/E_UNKNOWN_VERB"
    },
    "E_UNKNOWN_FLAG": {
      "status": "v0.1",
      "exit_code": 1,
      "retryable": false,
      "message_template": "unknown flag '<flag>' for verb '<verb>'",
      "details_schema_ref": "#/schemas/error_details/E_UNKNOWN_FLAG"
    },
    "E_MISSING_ARG": {
      "status": "v0.1",
      "exit_code": 1,
      "retryable": false,
      "message_template": "verb '<verb>' requires <arg_name>",
      "details_schema_ref": "#/schemas/error_details/E_MISSING_ARG"
    },
    "E_INVALID_ARG": {
      "status": "v0.1",
      "exit_code": 1,
      "retryable": false,
      "message_template": "invalid value for <arg_name>: '<given>' (expected: <description>)",
      "details_schema_ref": "#/schemas/error_details/E_INVALID_ARG"
    },
    "E_INCOMPATIBLE_FLAGS": {
      "status": "v0.1",
      "exit_code": 1,
      "retryable": false,
      "message_template": "flags <flag_a> and <flag_b> cannot be used together",
      "details_schema_ref": "#/schemas/error_details/E_INCOMPATIBLE_FLAGS"
    },
    "E_UNKNOWN_TASK": {
      "status": "v0.1",
      "exit_code": 1,
      "retryable": false,
      "message_template": "no routing rule for task '<task>'",
      "details_schema_ref": "#/schemas/error_details/E_UNKNOWN_TASK"
    },
    "E_UNKNOWN_MODEL": {
      "status": "v0.1",
      "exit_code": 1,
      "retryable": false,
      "message_template": "model '<model>' not found on any reachable backend",
      "details_schema_ref": "#/schemas/error_details/E_UNKNOWN_MODEL"
    },
    "E_UNKNOWN_BACKEND": {
      "status": "v0.1",
      "exit_code": 1,
      "retryable": false,
      "message_template": "no backend named '<backend>' in config",
      "details_schema_ref": "#/schemas/error_details/E_UNKNOWN_BACKEND"
    },
    "E_CONFIG_MISSING": {
      "status": "v0.1",
      "exit_code": 3,
      "retryable": false,
      "message_template": "no config file found",
      "details_schema_ref": "#/schemas/error_details/E_CONFIG_MISSING"
    },
    "E_CONFIG_INVALID": {
      "status": "v0.1",
      "exit_code": 3,
      "retryable": false,
      "message_template": "config file at <path> failed to parse",
      "details_schema_ref": "#/schemas/error_details/E_CONFIG_INVALID"
    },
    "E_CONFIG_UNREADABLE": {
      "status": "v0.1",
      "exit_code": 3,
      "retryable": false,
      "message_template": "config file at <path> could not be read: <reason>",
      "details_schema_ref": "#/schemas/error_details/E_CONFIG_UNREADABLE"
    },
    "E_NO_BACKENDS_CONFIGURED": {
      "status": "v0.1",
      "exit_code": 3,
      "retryable": false,
      "message_template": "config at <path> defines no backends",
      "details_schema_ref": "#/schemas/error_details/E_NO_BACKENDS_CONFIGURED"
    },
    "E_CONFIG_WRITE_FAILED": {
      "status": "v0.2",
      "exit_code": 3,
      "retryable": false,
      "message_template": "could not write config to <path>: <reason>",
      "details_schema_ref": "#/schemas/error_details/E_CONFIG_WRITE_FAILED"
    },
    "E_CONFIG_PATCH_DELETE_UNSUPPORTED": {
      "status": "v0.2",
      "exit_code": 1,
      "retryable": false,
      "message_template": "config patch deletion is not supported",
      "details_schema_ref": "#/schemas/error_details/E_CONFIG_PATCH_DELETE_UNSUPPORTED"
    },
    "E_CONFIG_KEY_UNKNOWN": {
      "status": "v0.2",
      "exit_code": 1,
      "retryable": false,
      "message_template": "config key '<key>' is not recognized",
      "details_schema_ref": "#/schemas/error_details/E_CONFIG_KEY_UNKNOWN"
    },
    "E_BACKEND_TIMEOUT": {
      "status": "v0.1",
      "exit_code": 4,
